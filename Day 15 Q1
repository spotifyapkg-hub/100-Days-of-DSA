#include <stdio.h>

int main() {
    int m, n;
    scanf("%d %d", &m, &n);

    int a[100][100];
    int sum = 0;

    for (int i = 0; i < m; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &a[i][j]);
        }
    }

    int min = (m < n) ? m : n;

    for (int i = 0; i < min; i++) {
        sum += a[i][i];
    }

    printf("%d", sum);

    return 0;
}
