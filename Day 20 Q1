#include <stdio.h>
#include <stdlib.h>

#define MAX 100000

typedef struct {
    long long key;
    int count;
} Hash;

int main() {
    int n;
    scanf("%d", &n);

    int arr[n];
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    long long prefixSum = 0;
    long long result = 0;

    Hash hash[MAX];
    int size = 0;

    hash[size++] = (Hash){0, 1};

    for (int i = 0; i < n; i++) {
        prefixSum += arr[i];

        int found = 0;
        for (int j = 0; j < size; j++) {
            if (hash[j].key == prefixSum) {
                result += hash[j].count;
                hash[j].count++;
                found = 1;
                break;
            }
        }

        if (!found) {
            hash[size++] = (Hash){prefixSum, 1};
        }
    }

    printf("%lld\n", result);

    return 0;
}
