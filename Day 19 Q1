#include <stdio.h>
#include <stdlib.h>

int cmp(const void *a, const void *b) {
    return (*(int*)a - *(int*)b);
}

int main() {
    int n;
    scanf("%d", &n);

    int arr[1000];

    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    qsort(arr, n, sizeof(int), cmp);

    int l = 0, r = n - 1;

    int minSum = 1000000000;
    int ans1 = arr[l], ans2 = arr[r];

    while (l < r) {
        int sum = arr[l] + arr[r];

        if (abs(sum) < abs(minSum)) {
            minSum = sum;
            ans1 = arr[l];
            ans2 = arr[r];
        }

        if (sum < 0) {
            l++;
        } else {
            r--;
        }
    }

    printf("%d %d", ans1, ans2);

    return 0;
}
