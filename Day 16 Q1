#include <stdio.h>

int main() {
    int n;
    scanf("%d", &n);

    int arr[1000], freq[1000] = {0};

    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    for (int i = 0; i < n; i++) {
        if (freq[i] == -1) continue;

        int count = 1;

        for (int j = i + 1; j < n; j++) {
            if (arr[i] == arr[j]) {
                count++;
                freq[j] = -1;
            }
        }

        freq[i] = count;
    }

    for (int i = 0; i < n; i++) {
        if (freq[i] != -1) {
            printf("%d:%d ", arr[i], freq[i]);
        }
    }

    return 0;
}
