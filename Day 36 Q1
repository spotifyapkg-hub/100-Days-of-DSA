#include <stdio.h>
#include <stdlib.h>

int main() {
    int n;
    scanf("%d", &n);

    int *q = (int*)malloc(n * sizeof(int));
    for (int i = 0; i < n; i++) scanf("%d", &q[i]);

    int m;
    scanf("%d", &m);

    int front = 0;

    front = (front + m) % n;

    for (int i = 0; i < n; i++) {
        printf("%d", q[(front + i) % n]);
        if (i < n - 1) printf(" ");
    }

    free(q);
    return 0;
}
